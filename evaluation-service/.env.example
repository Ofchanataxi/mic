PORT=3002
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/media_service?schema=evaluation

REDIS_URL=redis://localhost:6379
EVALUATION_QUEUE_NAME=evaluation-jobs
MAX_EVALUATION_ATTEMPTS=3

INTERVIEW_SERVICE_URL=http://localhost:3003
MEDIA_SERVICE_URL=http://localhost:3000
CANDIDATE_SERVICE_URL=http://localhost:3001
FEEDBACK_SERVICE_URL=http://localhost:3004

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

JUDGE0_API_KEY=
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

TEMP_PROCESSING_DIR=./tmp/evaluation

TECHNICAL_SEMANTIC_WEIGHT=0.8
TECHNICAL_AUDIO_WEIGHT=0.2
TECHNICAL_VIDEO_WEIGHT=0.0

SOFT_SEMANTIC_WEIGHT=0.7
SOFT_AUDIO_WEIGHT=0.3
SOFT_VIDEO_WEIGHT=0.0

CODE_CODE_WEIGHT=0.8
CODE_SEMANTIC_WEIGHT=0.2

ALLOW_COMPLETED_REPROCESS=false
INTERNAL_SERVICE_TOKEN=

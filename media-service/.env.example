PORT=3000
NODE_ENV=development
SERVICE_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_service?schema=public
REDIS_URL=redis://localhost:6379
GCS_PROJECT_ID=local-media-project
GCS_BUCKET_NAME=media-assets
GCS_EMULATOR_HOST=http://localhost:4443
MAX_FILE_SIZE_MB=250
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime,video/x-matroska
ALLOWED_PDF_TYPES=application/pdf
TEMP_UPLOAD_DIR=./tmp/uploads
QUEUE_NAME=media-processing
FFMPEG_VIDEO_CRF=28
FFMPEG_VIDEO_PRESET=veryfast
OUTPUT_VIDEO_WIDTH=1280
OUTPUT_VIDEO_MAX_FPS=30

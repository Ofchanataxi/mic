    {
      "name": "01 Auth via Gateway",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"firstName\": \"Pedro\",\n  \"lastName\": \"Piedra\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register success or existing user', () => pm.expect([201, 409]).to.include(pm.response.code));",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "  pm.collectionVariables.set('userId', body.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "pm.collectionVariables.set('userId', body.user.id);",
                  "pm.test('token saved', () => pm.expect(body.accessToken).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "header": [],
            "url": "{{gatewayUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('me ok', () => pm.response.to.have.status(200));",
                  "pm.test('user present', () => pm.expect(pm.response.json().user.id).to.eql(pm.collectionVariables.get('userId')));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh ok', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{gatewayUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login ok after seed', () => pm.expect([200, 401]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('adminAccessToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Users Admin",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminAccessToken}}", "type": "string" }
              ]
            },
            "header": [],
            "url": "{{gatewayUrl}}/api/v1/auth/admin/users"
          }
        }
      ]

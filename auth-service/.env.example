EMAIL_PORT=465
EMAIL_SECURE=true
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFICATION_EXPIRES_IN=24h
PASSWORD_RESET_EXPIRES_IN=1h

LOG_LEVEL=info
